{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "dist/main",
    "rootDir": "src/main",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/main/**/*"]
}
